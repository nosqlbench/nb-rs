/// @driver
/// cycle := meta
/// param_a := 100
/// param_b := 200

/// @selector
/// bucket := mod(hash(meta), 10)
/// output_idx := mod(bucket, 2)
//  0 = leaf_a (90%), 1 = leaf_b (10%)

/// @pull_weights
/// leaf_a: 90
/// leaf_b: 10

/// @graph
/// 100 nodes, 3 inputs (2 stable).
/// leaf_a: 30-node cycle-dependent cone (pulled 90%).
/// leaf_b: 70-node param-dependent cone (pulled 10%, cached).
/// Double optimization: provenance caches leaf_b's inputs,
/// AND it's rarely pulled.
inputs := (cycle, param_a, param_b)

// Cycle subgraph (30 nodes) — hot path
c0 := hash(cycle)
c1 := mod(c0, 997)
c2 := hash(c1)
c3 := mod(c2, 991)
c4 := hash(c3)
c5 := mod(c4, 983)
c6 := hash(c5)
c7 := mod(c6, 977)
