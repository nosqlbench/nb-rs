c21 := mod(c20, 929)
c22 := hash(c21)
c23 := mod(c22, 919)
c24 := hash(c23)
c25 := mod(c24, 911)
c26 := hash(c25)
c27 := mod(c26, 907)
c28 := hash(c27)
leaf_a := mod(c28, 887)

// Param subgraph (70 nodes) — cold path, stable inputs
p0 := hash(param_a)
p1 := mod(p0, 500)
